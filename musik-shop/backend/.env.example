PORT=3000
DB_HOST=localhost
DB_PORT=3306
# На Fedora/MariaDB root часто без пароля (только sudo mariadb).
# Используйте пользователя musik — см. database/setup-user.sql
DB_USER=musik
DB_PASSWORD=<см. db-credentials.txt в корне проекта>
DB_NAME=musik_shop
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d

# Разрешённые origin для CORS (через запятую). Пусто — разрешены все.
# CORS_ORIGIN=https://musik-shop.example.com

# Раздавать собранный фронтенд с этого же сервера (пути / и /api на одном хосте)
# SERVE_FRONTEND=1
